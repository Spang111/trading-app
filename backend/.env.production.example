# QuantFlow production environment template (Docker Compose)
#
# Copy this file to `.env.production` on the server and fill in real values:
#   cp .env.production.example .env.production
#
# Then run:
#   python3 check_env.py
#   docker compose up -d --build
#
# IMPORTANT:
# - ENV=production enforces strict validation (no localhost in BACKEND_CORS_ORIGINS).
# - DATABASE_URL must match the Postgres settings below (host should be "db" for compose).

# Environment
ENV=production
DEBUG=False
LOG_LEVEL=INFO

# App (optional)
APP_NAME=QuantFlow API
APP_VERSION=1.0.0

# Gunicorn (optional)
PORT=8000
WEB_CONCURRENCY=4

# JWT (MUST set)
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# TradingView webhook (MUST set)
TRADINGVIEW_PASSPHRASE=CHANGE_ME_TRADINGVIEW_PASSPHRASE
# Optional: keep TradingView whitelist default, or override with your own CIDR/IPs
TRADINGVIEW_IP_WHITELIST=52.89.214.238,34.212.75.30,54.218.48.199

# CORS (MUST set, no localhost/127.0.0.1 in production)
# Supports JSON list or comma-separated:
# BACKEND_CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# BACKEND_CORS_ORIGINS=https://app.example.com,https://admin.example.com
BACKEND_CORS_ORIGINS=["https://your-domain.example.com"]

# Reverse proxy / LB
# Set true only when the app is behind a trusted reverse proxy/LB and is NOT directly reachable by the public.
TRUST_PROXY_HEADERS=False

# Rate limiting (in-memory, per-process)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_RPS=10

# Health / shutdown (optional)
HEALTHCHECK_TIMEOUT_SECONDS=1.0
BACKGROUND_TASK_SHUTDOWN_TIMEOUT_SECONDS=10.0
DB_WAIT_TIMEOUT_SECONDS=60

# Optional proxy for outbound exchange calls (only if you need it)
# PROXY_URL=http://proxy:7890

# Exchanges (optional)
DEFAULT_EXCHANGE=okx
EXCHANGE_MARKETS_CACHE=okx,binance

# NowPayments (optional)
# NOWPAYMENTS_API_KEY=CHANGE_ME
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# Encryption key (optional, reserved)
# ENCRYPTION_KEY=CHANGE_ME

# -----------------------------
# PostgreSQL (used by the db service)
# -----------------------------
POSTGRES_DB=quantflow
POSTGRES_USER=quantflow
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD

# Database URL (MUST set, must match the values above)
DATABASE_URL=postgresql+asyncpg://quantflow:CHANGE_ME_DB_PASSWORD@db:5432/quantflow

