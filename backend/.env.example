# Environment: development | test | production
# Cloud deploy MUST set: ENV=production
ENV=development

# App
APP_NAME=QuantFlow API
APP_VERSION=1.0.0
BACKEND_PUBLIC_URL=http://localhost:8000
# Optional when you have a public frontend that should handle email verification pages
# FRONTEND_APP_URL=http://localhost:3000

# Debug / logging
# Cloud deploy MUST set: DEBUG=False
DEBUG=True
# Cloud deploy recommended: INFO or WARNING
LOG_LEVEL=DEBUG

# JWT (Cloud deploy MUST set)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database (Cloud deploy MUST set)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname?ssl=require

# TradingView webhook security (Cloud deploy MUST set TRADINGVIEW_PASSPHRASE)
TRADINGVIEW_IP_WHITELIST=52.89.214.238,34.212.75.30,54.218.48.199
TRADINGVIEW_PASSPHRASE=your_tradingview_passphrase

# CORS (Cloud deploy MUST set)
# Supports JSON list or comma-separated string:
# BACKEND_CORS_ORIGINS=["https://app.example.com","https://admin.example.com"]
# BACKEND_CORS_ORIGINS=https://app.example.com,https://admin.example.com
BACKEND_CORS_ORIGINS=http://localhost:3000

# Proxy (optional) - supports PROXY_URL or HTTP_PROXY
# PROXY_URL=http://127.0.0.1:7890

# Reverse proxy / LB (cloud)
# Set true only when running behind a trusted proxy that sets X-Forwarded-For.
TRUST_PROXY_HEADERS=False

# Rate limiting (in-memory, per-process)
RATE_LIMIT_ENABLED=True
RATE_LIMIT_RPS=10

# Health / shutdown
HEALTHCHECK_TIMEOUT_SECONDS=1.0
BACKGROUND_TASK_SHUTDOWN_TIMEOUT_SECONDS=10.0

# Exchanges
DEFAULT_EXCHANGE=okx
EXCHANGE_MARKETS_CACHE=okx,binance

# NowPayments (optional; manual payments can work without it)
# NOWPAYMENTS_API_KEY=your_nowpayments_api_key
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# Encryption key for API credentials (optional; kept for future use)
# ENCRYPTION_KEY=your_base64_32byte_key

# Email verification / SMTP
EMAIL_VERIFICATION_REQUIRED=False
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=1440
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
# EMAIL_TOKEN_SECRET=your_optional_dedicated_email_token_secret
# SMTP_HOST=smtp.example.com
SMTP_PORT=587
# SMTP_USERNAME=mailer@example.com
# SMTP_PASSWORD=change_me
# SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=AI Trading
SMTP_USE_TLS=True
SMTP_USE_SSL=False
